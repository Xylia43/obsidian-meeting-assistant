{
  "name": "obsidian-meeting-assistant",
  "version": "0.1.0",
  "description": "Obsidian 会议助手插件 - 录音、转写、笔记生成",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "obsidian",
    "meeting",
    "recording",
    "transcription"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.11.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.2",
    "husky": "^9.0.0",
    "obsidian": "latest",
    "tslib": "2.6.2",
    "typescript": "5.3.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.2.4"
  }
}
